# Required: API key for authenticating proxy requests
API_KEY=your-secret-api-key

# Optional: Google OAuth for dashboard (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=you@example.com
JWT_SECRET=change-me-to-a-random-string

# Public URL (used for OAuth callbacks)
PUBLIC_URL=http://localhost:3456

# Performance tuning
MAX_CONCURRENT_REQUESTS=3
MAX_BUDGET_PER_REQUEST=0.50
REQUEST_TIMEOUT_MS=300000
SESSION_TTL_HOURS=24

# Server
PORT=3456
DB_PATH=./data/analytics.db
